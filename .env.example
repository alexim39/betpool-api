# ========================================
# BetPool API — Environment Configuration
# ========================================

# Server
PORT=8383                          # Port the Express server listens on
NODE_ENV=development               # Environment: development | production | test

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/betpool?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_jwt_secret_here    # Secret key for signing JWT tokens
JWT_EXPIRY=7d                      # Token expiry duration

# BulkSMS Nigeria (OTP delivery)
BULKSMS_API_TOKEN=your_bulksms_api_token_here
BULKSMS_SENDER_ID=BetPool          # Sender ID displayed on SMS

# Email (Nodemailer — branded email tokens)
EMAIL_HOST=smtp.ethereal.email     # SMTP host
EMAIL_PORT=587                     # SMTP port (465 for secure)
EMAIL_SECURE=false                 # true for port 465, false otherwise
EMAIL_USER=                        # SMTP username
EMAIL_PASS=                        # SMTP password / app password
EMAIL_FROM="BetPool" <noreply@betpool.tech>  # From address

# Paystack
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxx
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret

# Flutterwave
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxx
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxx
FLUTTERWAVE_WEBHOOK_HASH=your_flutterwave_webhook_hash

# Bank Transfer Provider
BANK_TRANSFER_PROVIDER=paystack    # Options: paystack | flutterwave

# Frontend URL
FRONTEND_URL=http://localhost:4200

# Admin
ADMIN_EMAILS=admin@betpool.tech     # Comma-separated admin email addresses

# AI / DeepSeek
DEEPSEEK_API_KEY=                   # DeepSeek API key for Ora AI chatbot
